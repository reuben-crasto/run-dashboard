{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "framework": null,
  "routes": [
    { "src": "/api/auth/strava",     "dest": "/api/auth/strava.js" },
    { "src": "/api/auth/callback",   "dest": "/api/auth/callback.js" },
    { "src": "/api/status",          "dest": "/api/status.js" },
    { "src": "/api/activities",      "dest": "/api/activities.js" },
    { "src": "/api/activities/(.*)", "dest": "/api/activities/[id].js" },
    { "src": "/api/records",         "dest": "/api/records.js" },
    { "src": "/api/run-logs",        "dest": "/api/run-logs.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",                "dest": "/index.html" }
  ]
}
