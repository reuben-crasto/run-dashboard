{
  "name": "running-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal Strava running dashboard",
  "scripts": {
    "build": "npm --prefix client install && npm --prefix client run build",
    "dev": "concurrently -n api,client -c blue,magenta \"vercel dev --listen 3000\" \"npm:dev:client\"",
    "dev:client": "npm --prefix client run dev",
    "install:all": "npm install && npm --prefix client install"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
