# ── Strava ─────────────────────────────────────────────────────────────────────
# Register your app at https://www.strava.com/settings/api
# Set Authorization Callback Domain to your Vercel domain (or "localhost" for dev)
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=https://your-app.vercel.app/api/auth/callback
CLIENT_URL=https://your-app.vercel.app

# ── Supabase ────────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com → Settings → API
# Run this SQL once in the Supabase SQL editor before deploying:
#
#   create table strava_tokens (
#     id            integer primary key default 1,
#     access_token  text,
#     refresh_token text not null,
#     expires_at    bigint,
#     athlete       jsonb,
#     updated_at    timestamptz default now(),
#     constraint strava_tokens_single_row check (id = 1)
#   );
#
#   create table run_logs (
#     id           uuid primary key default gen_random_uuid(),
#     activity_id  text unique not null,
#     km1_rpe      int,
#     soreness     int,
#     overall      int,
#     notes        text,
#     logged_at    timestamptz default now()
#   );
#
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Optional: seed token for first deploy ────────────────────────────────────
# If migrating from Railway, paste the refresh_token from your old tokens.json.
# After the first successful OAuth on Vercel this is no longer needed.
# STRAVA_REFRESH_TOKEN=optional_seed_refresh_token
