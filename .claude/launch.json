{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Express API Server",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--watch", "src/index.js"],
      "cwd": "server",
      "port": 3001
    },
    {
      "name": "Vite React Client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "client",
      "port": 5173
    },
    {
      "name": "Both (concurrently)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    }
  ]
}
