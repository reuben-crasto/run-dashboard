# ── Strava ────────────────────────────────────────────────────────────────────
# Get Client ID + Secret from https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to: localhost
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REDIRECT_URI=http://localhost:3001/auth/callback
PORT=3001
CLIENT_URL=http://localhost:5173

# ── Supabase (Feature 3 — post-run logs) ──────────────────────────────────────
# Create a project at https://supabase.com, then run this SQL:
#
#   create table run_logs (
#     id           uuid primary key default gen_random_uuid(),
#     activity_id  text unique not null,
#     km1_rpe      int,
#     soreness     int,
#     overall      int,
#     notes        text,
#     logged_at    timestamptz default now()
#   );
#
# Find URL + anon key in: Project Settings → API
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Railway deployment ─────────────────────────────────────────────────────────
# After OAuth locally, copy refresh_token from server/tokens.json to:
#   STRAVA_REFRESH_TOKEN=<value>
#   STRAVA_ATHLETE_JSON=<stringified athlete object>  (optional)
#   STRAVA_REDIRECT_URI=https://your-app.railway.app/auth/callback
#   CLIENT_URL=https://your-app.vercel.app
# Plus all Supabase + Gemini vars above.
