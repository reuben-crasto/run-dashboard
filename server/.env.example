# ── Local dev ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Get Client ID + Secret from https://www.strava.com/settings/api
# Set "Authorization Callback Domain" to: localhost

STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REDIRECT_URI=http://localhost:3001/auth/callback
PORT=3001
CLIENT_URL=http://localhost:5173

# ── Railway deployment ────────────────────────────────────────────────────────
# Railway's filesystem is ephemeral — tokens.json is wiped on redeploy.
# After you complete OAuth locally, open server/tokens.json and copy the
# refresh_token value into Railway's environment variable dashboard:
#
#   STRAVA_REFRESH_TOKEN=<paste from tokens.json>
#   STRAVA_ATHLETE_JSON=<paste the athlete object as a JSON string> (optional)
#
# Also set these on Railway:
#   STRAVA_CLIENT_ID / STRAVA_CLIENT_SECRET / PORT=3001
#   STRAVA_REDIRECT_URI=https://your-railway-app.railway.app/auth/callback
#   CLIENT_URL=https://your-vercel-app.vercel.app
